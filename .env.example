# Non-secret runtime paths loaded by both `moeka.sh` (direct mode) and
# `docker compose` (host-side variable interpolation).
#
# Copy to `.env` and edit to suit. Use absolute paths — `~` is NOT expanded
# inside .env files. `$VAR` and `${VAR}` placeholders in .env itself also
# won't expand, but docker-compose.yml can expand them.
#
# Both files (.env and keys.env) live at the repo root and are gitignored.

# --- Moeka state: config.json, history, media, cron, skills cache ------------
# Version-controllable on its own, but typically a per-host tree.
MOEKA_STATE=/home/youruser/.nanobot

# --- Moeka workspace: files the agent reads and writes -----------------------
# Standardized location — turn this into its own git repo for portable
# agent identity (SOUL/AGENTS/HEARTBEAT docs, memory, skills, sessions).
MOEKA_WORKSPACE=/home/youruser/moeka-workspace

# --- Mode hints (optional) ---------------------------------------------------
# MOEKA_MODE=auto         # auto | direct | docker
# MOEKA_EXEC_ON_HOST=0    # 1 inside docker to route shell tool through nsenter
