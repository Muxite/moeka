# Moeka secrets file. Copy to `keys.env` and fill in real values.
# Any variable here is exported into the environment before Moeka starts,
# and `${VAR}` placeholders inside config.json are resolved from it.
#
# Format: KEY=VALUE   (no spaces around '=', no export keyword required).
# Quote values that contain spaces. Do NOT commit the real keys.env file.

# ----- LLM providers -----
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# ----- Channel credentials -----
TELEGRAM_TOKEN=
DISCORD_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ----- Tool integrations -----
BRAVE_API_KEY=
CANVAS_API_TOKEN=

# ----- Runtime overrides (optional) -----
# MOEKA_STATE=~/.nanobot          # State directory (config, workspace, history)
# MOEKA_EXEC_ON_HOST=0            # 1 inside Docker to route exec() through nsenter
# MOEKA_MODE=auto                 # auto | direct | docker (see moeka.sh)
